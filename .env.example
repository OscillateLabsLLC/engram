# Engram configuration example
# Copy to .env and customize

# Path to DuckDB database file
DUCKDB_PATH=./engram.duckdb

# OpenAI-compatible embeddings endpoint (LM Studio, Ollama, llama.cpp, hosted providers)
# Accepts a bare host, a /v1 base, or a full /v1/embeddings endpoint.
#   LM Studio: http://localhost:1234/v1
#   Ollama:    http://localhost:11434
EMBEDDING_URL=http://localhost:11434

# Embedding model name (must be available on the embeddings server, 768 dimensions)
#   LM Studio: text-embedding-nomic-embed-text-v1.5
#   Ollama:    nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# Bearer token for the embeddings endpoint, if it requires one (optional)
# EMBEDDING_API_KEY=

# Server port (for engram serve)
ENGRAM_PORT=3490

# Server URL (for engram stdio proxy to connect to the server)
ENGRAM_SERVER_URL=http://localhost:3490

# --- Dreamer (async knowledge extraction) ---

# LLM adapter for knowledge extraction: openai | claude-cli
# ENGRAM_LLM_ADAPTER=openai

# OpenAI-compatible chat-completions endpoint (openai adapter)
# Accepts a bare host, a /v1 base, or a full /v1/chat/completions endpoint.
# ENGRAM_LLM_ENDPOINT=http://localhost:11434/v1

# Chat model used for extraction (openai adapter)
# ENGRAM_LLM_MODEL=qwen3:8b

# Bearer token for the chat endpoint, if it requires one (optional)
# ENGRAM_LLM_API_KEY=

# Per-episode extraction timeout (Go duration)
# ENGRAM_LLM_TIMEOUT=60s

# Claude CLI binary (claude-cli adapter). Billing follows the CLI's auth:
# subscription login = plan usage, ANTHROPIC_API_KEY = metered API calls.
# ENGRAM_CLAUDE_BIN=claude

# Automatic dreaming interval (Go duration). Unset = disabled (default);
# trigger manually with: curl -X POST http://localhost:3490/api/v1/admin/dream
# ENGRAM_DREAM_INTERVAL=

# Comma-separated names that refer to the memory owner (e.g. "Mike,Mike Gray").
# Grounds extracted facts about the owner when episodes say "I"/"me"; also
# enables built-in aliases (I, me, my, user, the user). Unset = disabled.
# ENGRAM_OWNER_ALIASES=

# Comma-separated tags that exclude episodes from dreaming entirely (they are
# never crawled nor stamped; removing the tag makes them eligible again).
# ENGRAM_DREAM_SKIP_TAGS=
